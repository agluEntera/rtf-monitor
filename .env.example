# Jira
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_api_token

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# MySQL (Jira mirror DB)
MYSQL_SERVER=your_mysql_host
MYSQL_PORT=3306
MYSQL_DBNAME=your_db_name
MYSQL_USERNAME=your_username
MYSQL_PASSWORD=your_password

# Monitor settings
THRESHOLD_BUSINESS_DAYS=4
TARGET_PERCENT=70

# Mattermost (отключено по умолчанию, инструкция: Mattermost — инструкция.md)
MATTERMOST_ENABLED=false
MATTERMOST_PORT=8080
MATTERMOST_TOKEN=your_mattermost_token
